      "source": [
        "# ============================================================\n",
        "# Figure 9: Random Forest vs XGBoost Comparison\n",
        "# GitHub version (with (a) and (b) panel titles)\n",
        "# ============================================================\n",
        "\n",
        "from google.colab import drive\n",
        "drive.mount('/content/drive')\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "from matplotlib.gridspec import GridSpec\n",
        "\n",
        "# Configuration\n",
        "RF_COLOR = \"#3498db\"\n",
        "XGB_COLOR = \"#e67e22\"\n",
        "THRESHOLD_COLOR = \"#e74c3c\"\n",
        "\n",
        "# Locked empirical values from results.json\n",
        "metric_labels = [\"Accuracy\", \"Precision\", \"Recall\", \"F1-Score\"]\n",
        "rf_values = [99.6277, 96.2045, 99.9626, 98.0476]\n",
        "xgb_values = [97.7003, 84.302, 92.6658, 88.2863]\n",
        "rf_latency = 0.0091\n",
        "xgb_latency = 0.001959\n",
        "urllc_threshold = 10.0\n",
        "\n",
        "# Create figure with custom layout\n",
        "fig = plt.figure(figsize=(12, 11))\n",
        "gs = GridSpec(3, 1, figure=fig, height_ratios=[3, 1.2, 2.2], hspace=0.45)\n",
        "\n",
        "# Top panel: Detection Metrics Comparison (grouped bars)\n",
        "ax1 = fig.add_subplot(gs[0])\n",
        "x = np.arange(len(metric_labels))\n",
        "width = 0.35\n",
        "\n",
        "bars_rf = ax1.bar(x - width/2, rf_values, width,\n",
        "                  label=\"Random Forest\",\n",
        "                  color=RF_COLOR, edgecolor=\"black\", linewidth=1.2)\n",
        "bars_xgb = ax1.bar(x + width/2, xgb_values, width,\n",
        "                   label=\"XGBoost\",\n",
        "                   color=XGB_COLOR, edgecolor=\"black\", linewidth=1.2)\n",
        "ax1.set_ylabel(\"Score (%)\", fontsize=12)\n",
        "ax1.set_title(\"(a) Detection Metrics Comparison\", fontsize=13, fontweight=\"bold\", pad=10)\n",
        "ax1.set_xticks(x)\n",
        "ax1.set_xticklabels(metric_labels, fontsize=11)\n",
        "ax1.set_ylim(80, 102)\n",
        "ax1.legend(loc=\"lower left\", fontsize=11)\n",
        "ax1.grid(axis=\"y\", alpha=0.3)\n",
        "ax1.tick_params(axis='y', labelsize=11)\n",
        "for bars, vals in [(bars_rf, rf_values), (bars_xgb, xgb_values)]:\n",
        "    for bar, val in zip(bars, vals):\n",
        "        ax1.text(bar.get_x() + bar.get_width()/2, val + 0.3,\n",
        "                 f\"{val:.2f}%\", ha=\"center\", fontsize=9, fontweight=\"bold\")\n",
        "\n",
        "# Middle panel: URLLC zone (8-11 ms)\n",
        "latency_labels = [\"Random Forest\", \"XGBoost\"]\n",
        "latency_values = [rf_latency, xgb_latency]\n",
        "latency_colors = [RF_COLOR, XGB_COLOR]\n",
        "\n",
        "ax2_upper = fig.add_subplot(gs[1])\n",
        "ax2_upper.bar(latency_labels, latency_values, color=latency_colors,\n",
        "              edgecolor=\"black\", linewidth=1.2, width=0.4)\n",
        "ax2_upper.axhline(y=urllc_threshold, color=THRESHOLD_COLOR, linestyle=\"--\",\n",
        "                  linewidth=2.5, label=\"URLLC Threshold (10 ms)\")\n",
        "ax2_upper.set_ylim(8, 11)\n",
        "ax2_upper.spines['bottom'].set_visible(False)\n",
        "ax2_upper.tick_params(labelbottom=False, bottom=False)\n",
        "ax2_upper.set_title(\"(b) Inference Latency vs URLLC Safety Threshold\",\n",
        "                    fontsize=13, fontweight=\"bold\", pad=10)\n",
        "ax2_upper.legend(loc=\"upper right\", fontsize=11)\n",
        "ax2_upper.grid(axis=\"y\", alpha=0.3)\n",
        "ax2_upper.tick_params(axis='y', labelsize=11)\n",
        "ax2_upper.set_yticks([10])\n",
        "ax2_upper.set_yticklabels([\"10\"])\n",
        "\n",
        "# Bottom panel: Zoomed latency (0-0.012 ms)\n",
        "ax2_lower = fig.add_subplot(gs[2])\n",
        "bars_lat = ax2_lower.bar(latency_labels, latency_values, color=latency_colors,\n",
        "                         edgecolor=\"black\", linewidth=1.2, width=0.4)\n",
        "ax2_lower.set_ylabel(\"Latency (ms)\", fontsize=12)\n",
        "ax2_lower.set_ylim(0, 0.012)\n",
        "ax2_lower.spines['top'].set_visible(False)\n",
        "ax2_lower.grid(axis=\"y\", alpha=0.3)\n",
        "ax2_lower.tick_params(axis='both', labelsize=11)\n",
        "ax2_lower.set_yticks([0.000, 0.002, 0.004, 0.006, 0.008])\n",
        "ax2_lower.set_yticklabels([\"0.000\", \"0.002\", \"0.004\", \"0.006\", \"0.008\"])\n",
        "\n",
        "# Bar value labels\n",
        "for bar, val in zip(bars_lat, latency_values):\n",
        "    ax2_lower.text(bar.get_x() + bar.get_width()/2, val + 0.0004,\n",
        "                   f\"{val} ms\", ha=\"center\", fontsize=11, fontweight=\"bold\")\n",
        "\n",
        "# Break marks\n",
        "d = 0.012\n",
        "kwargs = dict(transform=ax2_upper.transAxes, color='k', clip_on=False, linewidth=1.5)\n",
        "ax2_upper.plot((-d, +d), (-d * 2, +d * 2), **kwargs)\n",
        "ax2_upper.plot((1 - d, 1 + d), (-d * 2, +d * 2), **kwargs)\n",
        "kwargs.update(transform=ax2_lower.transAxes)\n",
        "ax2_lower.plot((-d, +d), (1 - d * 2, 1 + d * 2), **kwargs)\n",
        "ax2_lower.plot((1 - d, 1 + d), (1 - d * 2, 1 + d * 2), **kwargs)\n",
        "\n",
        "# Summary annotation\n",
        "rf_budget = (rf_latency / urllc_threshold) * 100\n",
        "xgb_budget = (xgb_latency / urllc_threshold) * 100\n",
        "fig.text(0.5, 0.02,\n",
        "         f\"RF: {rf_latency} ms ({rf_budget:.3f}% URLLC)  |  \"\n",
        "         f\"XGBoost: {xgb_latency} ms ({xgb_budget:.4f}% URLLC)\",\n",
        "         ha=\"center\", fontsize=11, fontweight=\"bold\",\n",
        "         bbox=dict(boxstyle=\"round,pad=0.4\", facecolor=\"#f0f0f0\", edgecolor=\"black\"))\n",
        "\n",
        "plt.savefig(\"/content/drive/MyDrive/veremi_thesis/figure_rf_vs_xgboost_github.png\",\n",
        "            dpi=300, bbox_inches=\"tight\")\n",
        "plt.show()\n",
        "print(\"Saved: figure_rf_vs_xgboost_github.png\")"
      ]
    }
  ]
}
